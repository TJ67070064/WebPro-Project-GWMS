<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/order.css">
</head>
<body>
    <%- include('includes/navbar.ejs') %>

    <main class="main-content">
        <section class="page-header">
            <div>
                <h1>จัดการออเดอร์</h1>
                <p>ติดตามสถานะการจัดส่ง และจัดการรายการคำขอคลังสินค้า</p>
            </div>
            <div class="search-filter">
                <div class="input-wrapper">
                    <span class="material-symbols-outlined icon">search</span>
                    <input type="text" class="form-control" placeholder="ค้นหา...">
                </div>
                <div>
                    <button onclick="openModal('addOrderModal')" class="btn-primary" style="width: auto; padding: 10px 20px; margin-top: 0;">
                        <span class="material-symbols-outlined">add_notes</span>เพิ่มออเดอร์
                    </button>
                </div>
            </div>
        </section>

        <section class="stats-grid">
            <div class="stat-card">
                <div class="stat-title">รอการอนุมัติ</div>
                <div class="stat-info">
                    <h2>12</h2>
                    <span class="material-symbols-outlined" style="font-size: 24px; color: var(--info);">pending_actions</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-title">กำลังจัดส่ง</div>
                <div class="stat-info">
                    <h2>5</h2>
                    <span class="material-symbols-outlined" style="font-size: 24px; color: var(--warning);">shopping_cart</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-title">เสร็จสิ้น</div>
                <div class="stat-info">
                    <h2>8</h2>
                    <span class="material-symbols-outlined" style="font-size: 24px; color: var(--success);">local_shipping</span>
                </div>
            </div>
        </section>

        <section class="table-container">
            <table class="custom-table">
                <thead>
                <tr>
                    <th>หมายเลขใบเบิก</th>
                    <th>เวลา</th>
                    <th>รายการที่เบิก</th>
                    <th>ผู้เบิก</th>
                    <th>สถานะ</th>
                    <th>จำนวน</th>
                </tr>
                </thead>
                <tbody>
                    <% orders.forEach(order => { %>
                        <tr>
                            <td> <%= order.order_id %> </td>
                            <td> <%= order.timestamp %> </td>
                            <td> <%= order.product_name %> </td>
                            <td> <%= order.user_name %> </td>
                            <td> <%= order.status %> </td>
                            <td> <%= order.order_quantity %> </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </section>
    </main>
</body>
</html>
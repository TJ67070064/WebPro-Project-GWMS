<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/order.css">
    <link rel="stylesheet" href="/css/navbar.css">
</head>
<body>
    <%- include('includes/navbar.ejs') %>

    <main class="main-content">
        <section class="page-header">
            <div>
                <h1>จัดการออเดอร์</h1>
                <p>ติดตามสถานะการจัดส่ง และจัดการรายการคำขอคลังสินค้า</p>
            </div>
            <div class="search-filter">
                <div class="input-wrapper">
                    <span class="material-symbols-outlined icon">search</span>
                    <input type="text" class="form-control" placeholder="ค้นหา...">
                </div>
                <div>
                    <button onclick="openShowInventory('showInventoryModal')" class="btn-primary" style="width: auto; padding: 10px 20px; margin-top: 0;">
                        <span class="material-symbols-outlined">add_notes</span>เพิ่มออเดอร์
                    </button>
                </div>
            </div>
        </section>

        <section class="stats-grid">
            <div class="stat-card">
                <div class="stat-title">รอการอนุมัติ</div>
                <div class="stat-info">
                    <h2><%= stats["รอการอนุมัติ"] %></h2>
                    <span class="material-symbols-outlined" style="font-size: 24px; color: var(--info);">pending_actions</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-title">กำลังเตรียมสินค้า</div>
                <div class="stat-info">
                    <h2><%= stats["กำลังเตรียมสินค้า"] %></h2>
                    <span class="material-symbols-outlined" style="font-size: 24px; color: var(--warning);">shopping_cart</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-title">รอการจัดส่ง</div>
                <div class="stat-info">
                    <h2><%= stats["รอการจัดส่ง"] %></h2>
                    <span class="material-symbols-outlined" style="font-size: 24px; color: var(--success);">local_shipping</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-title">สินค้าออกจากโกดัง</div>
                <div class="stat-info">
                    <h2><%= stats["สินค้าออกจากโกดัง"] %></h2>
                    <span class="material-symbols-outlined" style="font-size: 24px; color: var(--warning);">delivery_truck_speed</span>
                </div>
            </div>
        </section>

        <section class="table-container">
            <table class="custom-table">
                <thead>
                <tr>
                    <th>สินค้าที่เบิก</th>
                    <th>รหัสสินค้า (SKU)</th>
                    <th>สร้างขึ้นเมื่อเวลา</th>
                    <th>ผู้เบิก</th>
                    <th>สถานะ</th>
                    <th>จำนวน</th>
                    <th>รายละเอียดออเดอร์</th>
                </tr>
                </thead>
                <tbody>
                    <% orders.forEach(order => { %>
                        <tr>
                            <td>
                                <div class="product-cell">
                                    <div class="icon-box" style="padding: 0; overflow: hidden; border: 1px solid rgba(255,255,255,0.1);">
                                        <img src="<%= order.image || 'https://images.unsplash.com/photo-1550291652-6ea9114a47b1?q=80&w=150&auto=format&fit=crop' %>" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1550291652-6ea9114a47b1?q=80&w=150&auto=format&fit=crop';" alt="<%= order.product_name %>" style="width: 100%; height: 100%; object-fit: cover;">
                                    </div>
                                    <div class="product-info">
                                        <h4><%= order.product_name %></h4>
                                        <p><%= order.details %></p>
                                    </div>
                                </div>
                            </td>
                            <td> <%= order.sku %> </td>
                            <td>
                            <%= new Date(order.timestamp).toLocaleString("th-TH", {
                                day: "numeric",
                                month: "short",
                                year: "numeric",
                                hour: "2-digit",
                                minute: "2-digit"
                            }) %>
                            </td>
                            <td> <%= order.user_name %> </td>
                            <td>
                                <div class="status-wrapper">
                                    <span class="status-badge status-<%= order.status %>">
                                        <%= order.status %>
                                    </span>

                                    <select class="form-control status-dropdown"
                                    <%= user.role === "staff" ? "disabled" : "" %>
                                    onchange="updateStatus(<%= order.order_id %>, this.value)">
                                        <option value="รอการอนุมัติ" <%= order.status === "รอการอนุมัติ" ? "selected" : "" %>>รอการอนุมัติ</option>
                                        <option value="กำลังเตรียมสินค้า" <%= order.status === "กำลังเตรียมสินค้า" ? "selected" : "" %>>กำลังเตรียมสินค้า</option>
                                        <option value="รอการจัดส่ง" <%= order.status === "รอการจัดส่ง" ? "selected" : "" %>>รอการจัดส่ง</option>
                                        <option value="สินค้าออกจากโกดัง" <%= order.status === "สินค้าออกจากโกดัง" ? "selected" : "" %>>สินค้าออกจากโกดัง</option>
                                    </select>
                                </div>
                            </td>
                            <td> <%= order.order_quantity %> </td>
                            <td> <%= order.detail %> </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </section>
    </main>

    
    <section class="modal-overlay" id="showInventoryModal">
        <div class="modal-box show-inventory-box">
            <h2 id="modalProductName" style="margin-bottom: 5px; font-size: 20px;">รายการสินค้าทั้งหมดที่สามารถเพิ่มได้</h2>
            
            <table>
                <thead>
                    <tr>
                        <th>รายละเอียดสินค้า</th>
                        <th>รหัสสินค้า</th>
                        <th>จำนวน</th>
                        <th>สร้างออเดอร์</th>
                    </tr>
                </thead>
                <tbody id="inventoryTableBody">
                </tbody>
            </table>
        </div>
    </section>

    <section class="modal-overlay" id="addOrderModal">
        <div class="modal-box">
            <h2 id="modalProductName" style="margin-bottom: 5px; font-size: 20px;">รายการสินค้า</h2>
            <p>เลือกจำนวนที่สินค้าสำหรับออเดอร์</p>
            <form id="addOrderForm" method="POST">
                <img id="addOrderImg">
                <h4 id="addOrderName"></h4>
                <h4 id="addOrderQty"></h4>
                <div>
                    <label class="modal-label" for="inputQuantity">จำนวนที่ต้องการเบิกในออเดอร์</label>
                    <input type="number" id="addMaxQuantity" name="inputQuantity" required min="0" class="form-control modal-input">
                </div>
                <div>
                    <label class="modal-label" for="detail">รายละเอียดที่เขียนในใบออเดอร์</label>
                    <input type="text" id="" name="detail" class="form-control modal-input" placeholder="โปรดระบุรายละเอียด">
                </div>
                <button type="submit">สร้างออเดอร์</button>
            </form>
        </div>
    </section>

    <section class="modal-overlay" id="errorModal">
        <div class="modal-box" id="errorBox">
            <h2 id="errMsgLabel" style="margin-bottom: 5px; font-size: 20px;">เกิดข้อผิดพลาด</h2>
            <p id="errMsgDetail"></p>
            <form method="GET" action="/orders">
                <button type="submit">กลับไปหน้าออเดอร์</button>
            </form>
        </div>
    </section>

    <script>
        async function openShowInventory() {
            const response = await fetch('/orders/add-orders');
            const inventory = await response.json();
            const tableBody = document.getElementById("inventoryTableBody");
            tableBody.innerHTML = "";
            inventory.forEach((row) => {
                    tableBody.innerHTML += `
                        <tr>
                            <td>
                                <div class="product-cell">
                                    <div class="icon-box-overlay">
                                        <img src="${row.image || 'https://surl.li/bwxsnz'}" onerror="this.src='https://surl.li/bwxsnz'">
                                    </div>
                                    <div class="product-info">
                                        <h4>${row.name}</h4>
                                    </div>
                                </div>
                            </td>
                            <td>${row.sku}</td>
                            <td>${row.quantity}</td>
                            <td><button onclick="showProduct(${row.id})">+</button></td>
                        </tr>
                        `
            });
            openModal("showInventoryModal");
        }

        async function showProduct(itemId) {
            const response = await fetch(`/api/product/${itemId}`);
            const inventory = await response.json();

            document.getElementById("addMaxQuantity").max = inventory.quantity;
            document.getElementById("addMaxQuantity").value = 0;
            document.getElementById("addOrderForm").action = `/orders/add-orders/${itemId}`;
            document.getElementById("addOrderImg").src = inventory.image;
            document.getElementById("addOrderName").innerHTML = inventory.name;
            document.getElementById("addOrderQty").innerHTML = "จำนวนที่มีในคลัง: " + inventory.quantity;

            closeModal("showInventoryModal");
            openModal("addOrderModal");
        }

       
async function updateStatus(orderId, status) {

    try {

        const response = await fetch(`/orders/update-status/${orderId}`, { 
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({ status })
        });

        const result = await response.json();

        if (result.success) {
            window.location.href = "/orders";
        } else {
            alert("ไม่สามารถเปลี่ยนสถานะได้");
        }

    } catch (error) {

        console.error(error);
        alert("เกิดข้อผิดพลาด");

    }

}

        function showError(message) {
            console.log("Error happended");
            document.getElementById("errMsgDetail").innerHTML = message;
            openModal("errorModal");
        }

        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            modal.style.display = 'flex';
            modal.classList.add('active'); 
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            modal.style.display = 'none';
            modal.classList.remove('active');
        }

        window.onclick = function (event) {
            if (event.target.classList.contains('modal-overlay')) {
                closeModal(event.target.id);
            }
        }
    </script>
    <% if (errMsg) { %>
        <script>
        showError("<%= errMsg %>");
        </script>
    <% } %>
</body>
</html>
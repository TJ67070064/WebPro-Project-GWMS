<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>GWMS - Inventory Management</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/navbar.css">
</head>

<body class="dashboard-layout">

    <%- include('includes/navbar') %>

    <main class="main-content">
        
        <div class="page-header">
            <div>
                <h2>รายการสินค้า</h2>
                
            </div>
            <div class="btn-group">
                <button class="btn-primary">
                    <span class="material-symbols-outlined">add_circle</span> Add Product
                </button>
            </div>
        </div>

        <div class="filter-bar">
            <div class="form-group" style="margin-bottom: 0;">
                <label>คำค้นหา</label>
                <div class="input-wrapper">
                    <span class="material-symbols-outlined icon">search</span>
                    <input type="text" class="form-control" placeholder="Search by name, SKU, or serial...">
                </div>
            </div>
            
            <div class="form-group" style="margin-bottom: 0;">
                <label>โรงงานผลิต</label>
                <select class="form-control">
                    <option value="">All Brands</option>
                    <option value="Fender">Fender</option>
                    <option value="Gibson">Gibson</option>
                    <option value="Ibanez">Ibanez</option>
                    <option value="Martin">Martin</option>
                    <option value="Ernie Ball">Ernie Ball</option>
                </select>
            </div>

            <div class="form-group" style="margin-bottom: 0;">
                <label>สถานะ</label>
                <select class="form-control">
                    <option value="">All Statuses</option>
                    <option value="instock">In Stock</option>
                    <option value="lowstock">Low Stock</option>
                    <option value="outstock">Out of Stock</option>
                </select>
            </div>

        </div>

        <div class="table-container">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>รายละเอียดสินค้า</th>
                        <th>แบรนด์</th>
                        <th>ID สินค้า</th>
                        <th>โซนจัดเก็บ</th>
                        <th style="text-align: center;">จำนวน</th>
                        <th>สถานะ</th>
                        <th style="text-align: right;">จัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(product => { %>
                            <%
                                let qtyColor = 'white';
                                let badgeClass = 'success';
                                let statusText = 'In Stock';

                                if (product.quantity == 0) {
                                    qtyColor = 'var(--danger)';
                                    badgeClass = 'danger';
                                    statusText = 'Out of Stock';
                                } else if (product.quantity <= 5) {
                                    qtyColor = 'var(--warning)';
                                    badgeClass = 'warning';
                                    statusText = 'Low Stock';
                                }
                                
                                // สุ่มสีจุดบ่งบอก Zone ตามประเภทสินค้า
                                let dotColor = 'cyan';
                                if (product.category === 'Acoustic') dotColor = 'orange';
                                else if (product.category === 'Accessory') dotColor = 'purple';
                            %>

                            <tr>
                                <td>
                                    <div class="product-cell">
                                        <div class="icon-box"><span class="material-symbols-outlined"><%= product.icon %></span></div>
                                        <div class="product-info">
                                            <h4><%= product.name %></h4>
                                            <p><%= product.details %></p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="product-info">
                                        <h4><%= product.brand %></h4>
                                        <span class="badge info"><%= product.category %></span>
                                    </div>
                                </td>
                                <td><span class="tag-mono">SKU: <%= product.sku %></span></td>
                                <td>
                                    <div class="zone-indicator">
                                        <div class="zone-dot <%= dotColor %>"></div>
                                        <%= product.zone %>
                                    </div>
                                </td>
                                <td style="text-align: center; font-weight: bold; font-size: 16px; color: <%= qtyColor %>;">
                                    <%= product.quantity %>
                                </td>
                                <td><span class="badge <%= badgeClass %>"><%= statusText %></span></td>
                                <td style="text-align: right;">
                                    <button class="btn-icon edit" title="Edit Item"><span class="material-symbols-outlined">edit_square</span></button>
                                    <button class="btn-icon" title="History"><span class="material-symbols-outlined">history</span></button>
                                    <button class="btn-icon" title="เพิ่มออเดอร์" onclick="loadAndShowOrderModal('<%= product.id %>')"><span class="material-symbols-outlined">add_notes</span></button>
                                </td>
                            </tr>
                        <% }) %>

                    <% } else { %>
                        <tr>
                            <td colspan="7" style="text-align: center; color: var(--text-muted); padding: 40px;">
                                <span class="material-symbols-outlined" style="font-size: 48px; opacity: 0.5; margin-bottom: 10px;">inventory_2</span>
                                <p>ไม่พบสินค้า สินค้าหมด.</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>

            <div class="pagination-wrapper">
                <div class="pagination-info">แสดง <strong>1</strong> – <strong><%= products ? products.length : 0 %></strong> : <strong><%= products ? products.length : 0 %></strong> ผลลัพท์</div>
                <div class="pagination">
                    <a href="#" class="page-item"><span class="material-symbols-outlined" style="font-size: 16px; transform: translateY(2px);">chevron_left</span></a>
                    <a href="#" class="page-item active">1</a>
                    <a href="#" class="page-item"><span class="material-symbols-outlined" style="font-size: 16px; transform: translateY(2px);">chevron_right</span></a>
                </div>
            </div>
        </div>

        <footer class="dash-footer">
            <div style="display: flex; gap: 10px; align-items: center;">
                <strong style="color: var(--primary);">GWMS</strong>
            </div>
            <div style="text-transform: uppercase; letter-spacing: 1px;">
                © 2026 Guitar Warehouse Systems. Secure Connection.
            </div>
            <div class="links">
                <a href="#">Privacy</a>
                <a href="#">Terms</a>
                <a href="#">Help Center</a>
            </div>
        </footer>

    </main>

        <!-- ส่วน Overlay ในการเพิ่มใบออเดอร์-->
    <section id="addOrderModal" class="modal-overlay">
        <div class="modal-box">
            <h2 id="modalProductName" style="margin-bottom: 5px; font-size: 20px;">Product Name</h2>
            <p id="modalDetails" style="color: var(--text-muted); margin-bottom: 20px; font-size: 14px;">Details</p>
            <!-- action เป็น empty ก่อน ไปเพิ่มใน function ด้านล่าง -->
            <form id="orderForm" method="POST" action="">
                <input type="hidden" name="productId" id="modalProductId">

                <div class="form-group">
                    <label>จำนวนที่ต้องการสั่ง มีทั้งหมด <span id="currentQuantity" style="color: var(--warning);"></span> ชิ้น</label>
                    <input id="quantityInput" type="number" name="quantity" class="form-control" required min="1" placeholder="ใส่จำนวน..." value="1">
                </div>

                <div class="form-group">
                    <label>ระบุรายละเอียดออเดอร์</label>
                    <input id="detailInput" type="text" name="detail" class="form-control" required placeholder="รายละเอียด...">
                </div>

                <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px;">
                    <button type="button" onclick="closeModal('addOrderModal')" class="btn-text">ยกเลิก</button>
                    <button type="submit" class="btn-primary" style="width: auto;">ยืนยันออเดอร์</button>
                </div>
            </form>
        </div>
    </section>

    <script>
        function openModal(id) {
            document.getElementById(id).classList.add('active');
        }
        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }
        // function openEditModal(id, name, role) {
        //     document.getElementById('editForm').action = '/admintool/edit/' + id;
        //     document.getElementById('editName').value = name;
        //     document.getElementById('editRole').value = role;
        //     openModal('editUserModal');
        // }

        //Demo
        async function loadAndShowOrderModal(productId) {
            try {
                // 1. Ask the server for the data
                const response = await fetch('/api/product/' + productId);

                if (!response.ok) throw new Error('Product not found');

                // 2. Convert to object
                const product = await response.json();

                // 3. Inject the data into the HTML elements we gave IDs to
                document.getElementById('modalProductName').innerText = "เบิกสินค้า: " + product.name;
                document.getElementById('modalDetails').innerText = product.details + " (" + product.sku + ")";
                document.getElementById('modalProductId').value = product.id;
                document.getElementById('currentQuantity').innerHTML = product.quantity;
                document.getElementById('quantityInput').max = product.quantity;
                document.getElementById('orderForm').action = `/inventory/add-order/${productId}`;
                
                // 4. Show the modal
                openModal('addOrderModal');
            } catch (err) {
                console.error("Error fetching product:", err);
                alert("ไม่สามารถดึงข้อมูลสินค้าได้");
            }
        }

        //ถ้าเปิด overlay แล้วไปกด click ด้านนอกจะออกให้อัตโนมัติ
        window.onclick = function (event) {
            if (event.target.classList.contains('modal-overlay')) {
                event.target.classList.remove('active');
            }
        }
    </script>
</body>
</html>
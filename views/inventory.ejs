<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>GWMS - จัดการคลังสินค้า</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <style>
        .modal-overlay {+
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.6);
            z-index: 9999;
            justify-content: center; align-items: center;
            backdrop-filter: blur(2px);
        }

        .modal-box {
            background: #1e1e1e; 
            color: #e0e0e0; 
            padding: 30px;
            border-radius: 12px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8); 
            opacity: 1 !important;
            visibility: visible !important;
            transform: scale(1) !important;
            display: block !important;
        }

        
        .modal-box h2, .modal-box h3, .modal-box strong {
            color: #ffffff !important;
        }

        .form-grid { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 15px; 
            margin-bottom: 15px; 
        }
        
        
        .modal-label { 
            font-size: 13px; 
            font-weight: 500; 
            color: #aaaaaa; 
        }
        
        
        .modal-input { 
            width: 100%; 
            margin-top: 5px; 
            background: rgba(0, 0, 0, 0.4) !important; 
            color: #ffffff !important; 
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            border-radius: 6px;
            padding: 8px 12px;
            box-sizing: border-box;
        }

        
        .modal-input option {
            background: #222222;
            color: #ffffff;
        }

        
        .modal-box div[style*="background: rgba(0,0,0,0.03)"] {
            background: rgba(255, 255, 255, 0.05) !important;
        }

        
        .modal-box button[style*="color: #888"] {
            color: #cccccc !important;
        }
        
       
        .modal-box p[style*="color: #666"] {
            color: #bbbbbb !important;
        }
        .modal-box strong[style*="color: #111"] {
            color: #ffffff !important;
        }

        .page-item.disabled { 
            pointer-events: none; 
            opacity: 0.4; 
        }
    </style>
</head>

<body class="dashboard-layout">

    <%- include('includes/navbar') %>

        <main class="main-content">
            <div class="page-header">
                <div>
                    <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 12px; color: var(--primary); font-weight: 700; margin-bottom: 5px;">ระบบโลจิสติกส์คลังสินค้า</p>
                    <h2>รายการสินค้าคงคลัง</h2>
                    <p>จัดการสินทรัพย์ในคลังสินค้าแบบรวมศูนย์ ตรวจสอบระดับสต็อกแบบเรียลไทม์ และติดตามหมายเลขซีเรียล (SKU)</p>
                </div>
                <div class="btn-group">
                    <button class="btn-primary" onclick="openModal('addModal')">
                        <span class="material-symbols-outlined">add_circle</span> เพิ่มสินค้า
                    </button>
                </div>
            </div>

            <div class="filter-bar">
                <div class="form-group" style="margin-bottom: 0;">
                    <label>ค้นหาสินค้า</label>
                    <div class="input-wrapper">
                        <span class="material-symbols-outlined icon">search</span>
                        <input type="text" id="searchInput" class="form-control" placeholder="ค้นหาด้วยชื่อ หรือ SKU...">
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label>ผู้ผลิต / แบรนด์</label>
                    <select id="brandFilter" class="form-control">
                        <option value="">ทุกแบรนด์</option>
                        <option value="Fender">Fender</option>
                        <option value="Gibson">Gibson</option>
                        <option value="Ibanez">Ibanez</option>
                        <option value="Martin">Martin</option>
                        <option value="Ernie Ball">Ernie Ball</option>
                    </select>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label>สถานะสต็อก</label>
                    <select id="statusFilter" class="form-control">
                        <option value="">ทุกสถานะ</option>
                        <option value="instock">มีสินค้า</option>
                        <option value="lowstock">สินค้าใกล้หมด</option>
                        <option value="outstock">สินค้าหมด</option>
                    </select>
                </div>
            </div>

            <div class="table-container">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>รายละเอียดสินค้า</th>
                            <th>แบรนด์</th>
                            <th>รหัสสินค้า (SKU)</th>
                            <th>โซนจัดเก็บ</th>
                            <th style="text-align: center;">จำนวน</th>
                            <th>สถานะ</th>
                            <th style="text-align: right;">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (products && products.length > 0) { %>
                            <% products.forEach(product => { %>
                                <% 
                                    let qtyColor = 'white'; let badgeClass = 'success'; let statusText = 'มีสินค้า'; let filterStatus = 'instock';
                                    if (product.quantity == 0) { qtyColor = 'var(--danger)'; badgeClass = 'danger'; statusText = 'สินค้าหมด'; filterStatus = 'outstock'; } 
                                    else if (product.quantity <= 5) { qtyColor = 'var(--warning)'; badgeClass = 'warning'; statusText = 'สินค้าใกล้หมด'; filterStatus = 'lowstock'; }
                                    let dotColor = 'cyan'; if (product.category === 'Acoustic') dotColor = 'orange'; else if (product.category === 'Accessory') dotColor = 'purple';
                                %>
                                <tr class="product-row" data-search="<%= product.name.toLowerCase() %> <%= product.sku.toLowerCase() %>" data-brand="<%= product.brand %>" data-status="<%= filterStatus %>">
                                    <td>
                                        <div class="product-cell">
                                            <div class="icon-box" style="padding: 0; overflow: hidden; border: 1px solid rgba(255,255,255,0.1);">
                                                <img src="<%= product.image || 'https://images.unsplash.com/photo-1550291652-6ea9114a47b1?q=80&w=150&auto=format&fit=crop' %>" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1550291652-6ea9114a47b1?q=80&w=150&auto=format&fit=crop';" alt="<%= product.name %>" style="width: 100%; height: 100%; object-fit: cover;">
                                            </div>
                                            <div class="product-info">
                                                <h4><%= product.name %></h4>
                                                <p><%= product.details %></p>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="product-info">
                                            <h4><%= product.brand %></h4>
                                            <span class="badge info"><%= product.category %></span>
                                        </div>
                                    </td>
                                    <td><span class="tag-mono">SKU: <%= product.sku %></span></td>
                                    <td>
                                        <div class="zone-indicator">
                                            <div class="zone-dot <%= dotColor %>"></div>
                                            <%= product.zone %>
                                        </div>
                                    </td>
                                    <td style="text-align: center; font-weight: bold; font-size: 16px; color: <%= qtyColor %>;"><%= product.quantity %></td>
                                    <td><span class="badge <%= badgeClass %>"><%= statusText %></span></td>
                                    <td style="text-align: right;">
                                        <div style="display: flex; gap: 5px; justify-content: flex-end; align-items: center;">
                                            <button class="btn-icon" title="ดูรายละเอียด" 
                                                onclick="openViewModal(this)"
                                                data-name="<%= product.name %>" 
                                                data-sku="<%= product.sku %>" 
                                                data-brand="<%= product.brand %>"
                                                data-category="<%= product.category %>" 
                                                data-zone="<%= product.zone %>" 
                                                data-quantity="<%= product.quantity %>"
                                                data-details="<%= product.details %>" 
                                                data-image="<%= product.image %>">
                                                <span class="material-symbols-outlined">visibility</span>
                                            </button>

                                            <button class="btn-icon edit" title="แก้ไข" onclick="openEditProductModal(this)" data-id="<%= product.id %>" data-name="<%= product.name %>" data-sku="<%= product.sku %>" data-brand="<%= product.brand %>" data-category="<%= product.category %>" data-zone="<%= product.zone %>" data-quantity="<%= product.quantity %>" data-details="<%= product.details %>" data-image="<%= product.image %>">
                                                <span class="material-symbols-outlined">edit_square</span>
                                            </button>

                                            <button type="button" class="btn-icon" title="ประวัติการเคลื่อนไหว" onclick="openHistoryModal('<%= product.id %>', '<%= product.name %>')">
                                                <span class="material-symbols-outlined">history</span>
                                            </button>

                                            <% if (user && user.role !== 'staff') { %>
                                                <button type="button" class="btn-icon" title="ลบสินค้า" style="color: var(--danger);" onclick="openDeleteModal('<%= product.id %>', '<%= product.name %>')">
                                                    <span class="material-symbols-outlined">delete</span>
                                                </button>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="7" id="noDataRow" style="text-align: center; color: var(--text-muted); padding: 40px;"><span class="material-symbols-outlined" style="font-size: 48px; opacity: 0.5; margin-bottom: 10px;">inventory_2</span><p>ไม่พบสินค้าในคลัง</p></td></tr>
                        <% } %>
                    </tbody>
                </table>
                
                <div class="pagination-wrapper">
                    <div class="pagination-info" id="visibleCountDisplay">
                        กำลังโหลดข้อมูล...
                    </div>
                    <div class="pagination" id="paginationControls"></div>
                </div>

            </div>

            <footer class="dash-footer">
                <div style="display: flex; gap: 10px; align-items: center;">
                    <strong style="color: var(--primary);">GWMS</strong>
                    <span>v2.4.1 (Stable)</span>
                </div>
                <div style="text-transform: uppercase; letter-spacing: 1px;">
                    © 2026 Guitar Warehouse Systems.
                </div>
            </footer>
        </main>

        <div id="viewModal" class="modal-overlay">
            <div class="modal-box" style="max-width: 650px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="margin: 0; color: #111; display: flex; align-items: center; gap: 10px;">
                        <span class="material-symbols-outlined" style="color: var(--primary);">inventory_2</span>
                        รายละเอียดสินค้า
                    </h3>
                    <button type="button" onclick="closeModal('viewModal')" style="background: none; border: none; cursor: pointer; color: #888;"><span class="material-symbols-outlined">close</span></button>
                </div>
                
                <div style="display: flex; gap: 20px; margin-bottom: 20px; align-items: flex-start;">
                    <div style="flex: 1; border-radius: 8px; overflow: hidden; border: 1px solid rgba(0,0,0,0.1); background: #111;">
                        <img id="viewImage" src="" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1550291652-6ea9114a47b1?q=80&w=400&auto=format&fit=crop';" alt="Product Image" style="width: 100%; height: 200px; object-fit: cover; display: block;">
                    </div>
                    
                    <div style="flex: 1.5; display: flex; flex-direction: column; gap: 12px;">
                        <div>
                            <div style="font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;">ชื่อสินค้า</div>
                            <div id="viewName" style="font-size: 18px; font-weight: 700; color: #ffffff;">-</div>
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                            <div>
                                <div style="font-size: 12px; color: var(--text-muted);">รหัสสินค้า (SKU)</div>
                                <div id="viewSku" style="font-weight: 500;">-</div>
                            </div>
                            <div>
                                <div style="font-size: 12px; color: var(--text-muted);">จำนวนในสต็อก</div>
                                <div id="viewQuantity" style="font-weight: 800; color: var(--primary); font-size: 16px;">-</div>
                            </div>
                            <div>
                                <div style="font-size: 12px; color: var(--text-muted);">แบรนด์</div>
                                <div id="viewBrand">-</div>
                            </div>
                            <div>
                                <div style="font-size: 12px; color: var(--text-muted);">หมวดหมู่</div>
                                <div id="viewCategory">-</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div style="background: rgba(0,0,0,0.03); padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div>
                            <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 3px;">โซน/ตำแหน่งจัดเก็บ</div>
                            <div id="viewZone" style="display: flex; align-items: center; gap: 5px; font-weight: 500;">
                                <span class="material-symbols-outlined" style="font-size: 16px; color: var(--info);">location_on</span>
                                <span id="viewZoneText">-</span>
                            </div>
                        </div>
                        <div>
                            <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 3px;">รายละเอียด / สี</div>
                            <div id="viewDetails">-</div>
                        </div>
                    </div>
                </div>

                <div style="display: flex; justify-content: flex-end;">
                    <button type="button" class="btn-outline" onclick="closeModal('viewModal')">ปิดหน้าต่าง</button>
                </div>
            </div>
        </div>

        <div id="addModal" class="modal-overlay">
            <div class="modal-box">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="margin: 0; color: #111;">เพิ่มสินค้าใหม่</h3>
                    <button type="button" onclick="closeModal('addModal')" style="background: none; border: none; cursor: pointer; color: #888;"><span class="material-symbols-outlined">close</span></button>
                </div>
                <form id="addProductForm" action="/inventory/add" method="POST" style="display: flex; flex-direction: column;">
                    <div class="form-grid">
                        <div><label class="modal-label">ชื่อสินค้า</label><input type="text" name="name" required class="form-control modal-input" placeholder="เช่น Stratocaster"></div>
                        <div><label class="modal-label">รหัสสินค้า (SKU)</label><input type="text" name="sku" required class="form-control modal-input" placeholder="เช่น FND-001"></div>
                    </div>
                    <div class="form-grid">
                    <div>
                        <label class="modal-label">แบรนด์</label>
                        <select id="brandSelect" name="brand" class="form-control modal-input" onchange="toggleOtherBrand()">
                            <option value="Fender">Fender</option>
                            <option value="Gibson">Gibson</option>
                            <option value="Ibanez">Ibanez</option>
                            <option value="Martin">Martin</option>
                            <option value="Ernie Ball">Ernie Ball</option>
                            <option value="other">อื่นๆ</option>
                        </select>
                        <input type="text" id="otherBrandInput" class="form-control modal-input" placeholder="พิมพ์ชื่อแบรนด์" style="display:none; margin-top:8px;">
                    </div>
                        <div><label class="modal-label">หมวดหมู่</label>
                            <select name="category" required class="form-control modal-input">
                                <option value="Electric">Electric</option>
                                <option value="Acoustic">Acoustic</option>
                                <option value="Accessory">Accessory</option>
                                <option value="Bass">Bass</option>
                                <option value="Pedal">Pedal</option>
                                <option value="Amplifier">Amplifier</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-grid" style="grid-template-columns: 2fr 1fr;">
                        <div><label class="modal-label">โซน/ตำแหน่ง</label><input type="text" name="zone" required class="form-control modal-input"></div>
                        <div><label class="modal-label">จำนวนสต็อก</label><input type="number" name="quantity" required min="0" value="0" class="form-control modal-input"></div>
                    </div>
                    <div style="margin-bottom: 20px;"><label class="modal-label">รายละเอียด</label><input type="text" name="details" class="form-control modal-input"></div>
                    <div style="margin-bottom: 20px;"><label class="modal-label">ลิงก์รูปภาพ (URL)</label><input type="text" name="image" class="form-control modal-input"></div>
                    <div style="display: flex; gap: 10px;">
                        <button type="submit" class="btn-primary" style="flex: 1; justify-content: center;">บันทึกสินค้า</button>
                        <button type="button" class="btn-outline" onclick="resetAddForm()" style="flex: 1; justify-content: center;">ยกเลิก</button>
                    </div>
                </form>
            </div>
        </div>

        <div id="editModal" class="modal-overlay">
            <div class="modal-box">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="margin: 0; color: #111;">แก้ไขข้อมูลสินค้า</h3>
                    <button type="button" onclick="closeModal('editModal')" style="background: none; border: none; cursor: pointer; color: #888;"><span class="material-symbols-outlined">close</span></button>
                </div>
                <form id="editProductForm" method="POST" style="display: flex; flex-direction: column;">
                    <div class="form-grid">
                        <div><label class="modal-label">ชื่อสินค้า</label><input type="text" id="editName" name="name" required class="form-control modal-input"></div>
                        <div><label class="modal-label">รหัสสินค้า (SKU)</label><input type="text" id="editSku" name="sku" required class="form-control modal-input" readonly style="background: rgba(0,0,0,0.05); cursor: not-allowed;"></div>
                    </div>
                    <div class="form-grid">
                        <div>
                            <label class="modal-label">แบรนด์</label>
                                <select id="editBrand" name="brand" class="form-control modal-input" onchange="toggleEditOtherBrand()">
                                    <option value="Fender">Fender</option>
                                    <option value="Gibson">Gibson</option>
                                    <option value="Ibanez">Ibanez</option>
                                    <option value="Martin">Martin</option>
                                    <option value="Ernie Ball">Ernie Ball</option>
                                    <option value="other">อื่นๆ</option>
                                </select>
                                <input type="text" id="editOtherBrandInput" class="form-control modal-input" placeholder="พิมพ์ชื่อแบรนด์" style="display:none; margin-top:8px;">
                        </div>
                        <div><label class="modal-label">หมวดหมู่</label>
                            <select id="editCategory" name="category" required class="form-control modal-input">
                                <option value="Electric">Electric</option>
                                <option value="Acoustic">Acoustic</option>
                                <option value="Accessory">Accessory</option>
                                <option value="Bass">Bass</option>
                                <option value="Pedal">Pedal</option>
                                <option value="Amplifier">Amplifier</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-grid" style="grid-template-columns: 2fr 1fr;">
                        <div><label class="modal-label">โซน/ตำแหน่ง</label><input type="text" id="editZone" name="zone" required class="form-control modal-input"></div>
                        <div><label class="modal-label">จำนวนสต็อก</label><input type="number" id="editQuantity" name="quantity" required min="0" class="form-control modal-input"></div>
                    </div>
                    <div style="margin-bottom: 20px;"><label class="modal-label">รายละเอียด</label><input type="text" id="editDetails" name="details" class="form-control modal-input"></div>
                    <div style="margin-bottom: 20px;"><label class="modal-label">ลิงก์รูปภาพ (URL)</label><input type="text" id="editImage" name="image" class="form-control modal-input"></div>
                    <div style="display: flex; gap: 10px;">
                        <button type="submit" class="btn-primary" style="flex: 1; justify-content: center;">อัปเดตสินค้า</button>
                        <button type="button" class="btn-outline" onclick="closeModal('editModal')" style="flex: 1; justify-content: center;">ยกเลิก</button>
                    </div>
                </form>
            </div>
        </div>

        <div id="historyModal" class="modal-overlay">
            <div class="modal-box" style="max-width: 600px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="margin: 0; color: #111;">ประวัติการทำรายการ: <br><span id="historyItemName" style="color: var(--primary); font-size: 16px;"></span></h3>
                    <button type="button" onclick="closeModal('historyModal')" style="background: none; border: none; cursor: pointer; color: #888;"><span class="material-symbols-outlined">close</span></button>
                </div>
                <div class="table-container" style="max-height: 400px; overflow-y: auto; background: rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.05); box-shadow: none;">
                    <table class="custom-table" style="font-size: 13px;">
                        <thead><tr><th>วันที่-เวลา</th><th>ผู้ทำรายการ</th><th>สถานะ</th><th style="text-align: center;">จำนวน</th><th>หมายเหตุ</th></tr></thead>
                        <tbody id="historyTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="deleteConfirmModal" class="modal-overlay" style="z-index: 100000;">
            <div class="modal-box" style="max-width: 400px; text-align: center; padding: 40px 30px;">
                <div style="background: #ffebee; color: #dc3545; width: 60px; height: 60px; border-radius: 50%; display: flex; justify-content: center; align-items: center; margin: 0 auto 20px auto;">
                    <span class="material-symbols-outlined" style="font-size: 32px;">warning</span>
                </div>
                <h3 style="color: #111; margin-bottom: 10px;">ยืนยันการลบสินค้า</h3>
                <p style="color: #666; font-size: 14px; margin-bottom: 30px;">
                    คุณแน่ใจหรือไม่ว่าต้องการลบ <strong id="deleteItemName" style="color: #111;"></strong> ?<br>
                    <span style="color: #dc3545; font-size: 12px; margin-top: 5px; display: inline-block;">การลบนี้ไม่สามารถกู้คืนได้</span>
                </p>
                <form id="deleteProductForm" method="POST" style="display: flex; gap: 10px;">
                    <button type="button" class="btn-outline" onclick="closeModal('deleteConfirmModal')" style="flex: 1; display: flex; justify-content: center;">ยกเลิก</button>
                    <button type="submit" class="btn-primary" style="flex: 1; display: flex; justify-content: center; background: #dc3545; border-color: #dc3545;">ลบสินค้าถาวร</button>
                </form>
            </div>
        </div>

        <script>
            function openModal(modalId) {
                const modal = document.getElementById(modalId);
                modal.style.display = 'flex';
                modal.classList.add('active'); 
            }
            function closeModal(modalId) {
                const modal = document.getElementById(modalId);
                modal.style.display = 'none';
                modal.classList.remove('active');
            }

            window.onclick = function (event) {
                if (event.target.classList.contains('modal-overlay')) {
                    closeModal(event.target.id);
                }
            }

            
            function openViewModal(btn) {
                document.getElementById('viewName').textContent = btn.getAttribute('data-name') || '-';
                document.getElementById('viewSku').textContent = btn.getAttribute('data-sku') || '-';
                document.getElementById('viewBrand').textContent = btn.getAttribute('data-brand') || '-';
                document.getElementById('viewCategory').textContent = btn.getAttribute('data-category') || '-';
                document.getElementById('viewZoneText').textContent = btn.getAttribute('data-zone') || '-';
                document.getElementById('viewQuantity').textContent = (btn.getAttribute('data-quantity') || '0') + ' ชิ้น';
                
                const details = btn.getAttribute('data-details');
                document.getElementById('viewDetails').textContent = details ? details : '-ไม่มีระบุ-';
                
                let imgUrl = btn.getAttribute('data-image');
                if (!imgUrl || imgUrl === 'null' || imgUrl.trim() === '') {
                    imgUrl = 'https://images.unsplash.com/photo-1550291652-6ea9114a47b1?q=80&w=400&auto=format&fit=crop';
                }
                document.getElementById('viewImage').src = imgUrl;
                
                openModal('viewModal');
            }

            function openDeleteModal(id, name) {
                document.getElementById('deleteItemName').textContent = name;
                document.getElementById('deleteProductForm').action = '/inventory/delete/' + id;
                openModal('deleteConfirmModal');
            }

            function openEditProductModal(btn) {
                document.getElementById('editProductForm').action = '/inventory/edit/' + btn.getAttribute('data-id');
                document.getElementById('editName').value = btn.getAttribute('data-name');
                document.getElementById('editSku').value = btn.getAttribute('data-sku');
                const brand = btn.getAttribute('data-brand');
                const brandSelect = document.getElementById('editBrand');

                let exists = false;
                for (let option of brandSelect.options) {
                    if (option.value === brand) { exists = true; break; }
                }
                if (!exists) {
                    const newOption = document.createElement("option");
                    newOption.value = brand;
                    newOption.text = brand;

                    const otherOption = brandSelect.querySelector('option[value="other"]');
                    if (otherOption) brandSelect.insertBefore(newOption, otherOption);
                    else brandSelect.appendChild(newOption);
                }
                brandSelect.value = brand;

                document.getElementById('editCategory').value = btn.getAttribute('data-category');
                document.getElementById('editZone').value = btn.getAttribute('data-zone');
                document.getElementById('editQuantity').value = btn.getAttribute('data-quantity');
                document.getElementById('editDetails').value = btn.getAttribute('data-details');
                document.getElementById('editImage').value = btn.getAttribute('data-image');
                openModal('editModal');
            }

            function toggleOtherBrand(){
                const select = document.getElementById("brandSelect");
                const input = document.getElementById("otherBrandInput");
                if(select.value === "other"){
                    input.style.display = "block"; input.name = "brand"; select.name = "";
                }else{
                    input.style.display = "none"; input.name = ""; select.name = "brand"; input.value = "";
                }
            }

            function toggleEditOtherBrand(){
                const select = document.getElementById("editBrand");
                const input = document.getElementById("editOtherBrandInput");
                if(select.value === "other"){
                    input.style.display = "block"; input.name = "brand"; select.name = "";
                }else{
                    input.style.display = "none"; input.name = ""; select.name = "brand"; input.value = "";
                }
            }

            function resetAddForm(){
                const form = document.getElementById("addProductForm");
                const select = document.getElementById("brandSelect");
                const input = document.getElementById("otherBrandInput");
                form.reset();
                input.style.display = "none"; input.value = "";
                select.name = "brand"; input.name = "";
                closeModal("addModal");
            }

            async function openHistoryModal(id, name) {
                document.getElementById('historyItemName').textContent = name;
                openModal('historyModal');
                const tbody = document.getElementById('historyTableBody');
                tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 20px;">กำลังโหลดข้อมูล...</td></tr>';
                try {
                    const response = await fetch(`/api/inventory/history/${id}`);
                    const data = await response.json();
                    if (data.length > 0) {
                        let html = '';
                        data.forEach(log => {
                            let badgeClass = 'info';
                            if(log.status === 'Completed') badgeClass = 'success';
                            else if(log.status === 'Pending') badgeClass = 'warning';
                            else if(log.status === 'Cancelled') badgeClass = 'danger';
                            else if(log.status === 'Updated') badgeClass = 'info';

                            html += `<tr style="background: white;">
                                <td style="color: #666;">${log.timestamp}</td>
                                <td style="font-weight: 500; color: #111;">${log.user_name}</td>
                                <td><span class="badge ${badgeClass}">${log.status}</span></td>
                                <td style="text-align: center; font-weight: bold; color: var(--primary);">${log.order_quantity}</td>
                                <td style="color: #666;">${log.detail || '-'}</td>
                            </tr>`;
                        });
                        tbody.innerHTML = html;
                    } else {
                        tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 30px; color: #666;">ยังไม่มีประวัติการทำรายการสำหรับสินค้านี้</td></tr>';
                    }
                } catch (error) {
                    console.error('Error:', error);
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 20px; color: red;">เกิดข้อผิดพลาดในการดึงข้อมูล</td></tr>';
                }
            }

            document.addEventListener('DOMContentLoaded', () => {
                const searchInput = document.getElementById('searchInput');
                const brandFilter = document.getElementById('brandFilter');
                const statusFilter = document.getElementById('statusFilter');
                const productRows = document.querySelectorAll('.product-row');
                
                const visibleCountDisplay = document.getElementById('visibleCountDisplay');
                const paginationControls = document.getElementById('paginationControls');

                let currentPage = 1;
                const rowsPerPage = 10;
                let filteredRows = [];

                function filterTable() {
                    const searchTerm = searchInput.value.toLowerCase();
                    const selectedBrand = brandFilter.value;
                    const selectedStatus = statusFilter.value;
                    
                    filteredRows = [];

                    productRows.forEach(row => {
                        const rowSearchText = row.getAttribute('data-search');
                        const rowBrand = row.getAttribute('data-brand');
                        const rowStatus = row.getAttribute('data-status');

                        const matchesSearch = rowSearchText.includes(searchTerm);
                        const matchesBrand = selectedBrand === "" || rowBrand === selectedBrand;
                        const matchesStatus = selectedStatus === "" || rowStatus === selectedStatus;

                        if (matchesSearch && matchesBrand && matchesStatus) {
                            filteredRows.push(row);
                        } else {
                            row.style.display = 'none';
                        }
                    });

                    currentPage = 1; 
                    renderPagination();
                }

                function renderPagination() {
                    const totalRows = filteredRows.length;
                    const totalPages = Math.ceil(totalRows / rowsPerPage) || 1;

                    const start = (currentPage - 1) * rowsPerPage;
                    const end = start + rowsPerPage;

                    filteredRows.forEach((row, index) => {
                        if (index >= start && index < end) {
                            row.style.display = '';
                        } else {
                            row.style.display = 'none';
                        }
                    });

                    const displayStart = totalRows === 0 ? 0 : start + 1;
                    const displayEnd = Math.min(end, totalRows);
                    
                    if (visibleCountDisplay) {
                        visibleCountDisplay.innerHTML = `แสดง <strong>${displayStart}</strong> ถึง <strong>${displayEnd}</strong> จากทั้งหมด <strong>${totalRows}</strong> รายการ`;
                    }

                    setupPaginationUI(totalPages);
                }

                function setupPaginationUI(totalPages) {
                    if (!paginationControls) return;
                    let html = '';
                    html += `<a href="#" class="page-item ${currentPage === 1 ? 'disabled' : ''}" onclick="changePage(event, ${currentPage - 1})"><span class="material-symbols-outlined" style="font-size: 16px; transform: translateY(2px);">chevron_left</span></a>`;
                    for (let i = 1; i <= totalPages; i++) {
                        html += `<a href="#" class="page-item ${i === currentPage ? 'active' : ''}" onclick="changePage(event, ${i})">${i}</a>`;
                    }
                    html += `<a href="#" class="page-item ${currentPage === totalPages ? 'disabled' : ''}" onclick="changePage(event, ${currentPage + 1})"><span class="material-symbols-outlined" style="font-size: 16px; transform: translateY(2px);">chevron_right</span></a>`;
                    paginationControls.innerHTML = html;
                }

                window.changePage = function(event, page) {
                    event.preventDefault();
                    const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
                    if (page >= 1 && page <= totalPages) {
                        currentPage = page;
                        renderPagination();
                    }
                };

                if(searchInput) searchInput.addEventListener('input', filterTable);
                if(brandFilter) brandFilter.addEventListener('change', filterTable);
                if(statusFilter) statusFilter.addEventListener('change', filterTable);

                filterTable();
            });
        </script>
</body>
</html>
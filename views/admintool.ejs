<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GWMS AdminTools</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="dashboard-layout">

    <%- include('includes/navbar') %>

    <main class="main-content">
        
        <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <h2 style="margin: 0;">จัดการผู้ใช้</h2>
            <button onclick="openModal('addUserModal')" class="btn-primary" style="width: auto; padding: 10px 20px; margin-top: 0;">
                <span class="material-symbols-outlined">person_add</span>
                เพิ่มผู้ใช้
            </button>
        </div>

        <div class="table-container">
            <div class="table-header">
                <div style="display: flex; align-items: center; gap: 10px; font-weight: 700;">
                    <span class="material-symbols-outlined" style="color: var(--primary);">group</span>
                    System Users
                </div>
                <span class="badge info">Total: <%= (typeof dbUsers !== 'undefined') ? dbUsers.length : 0 %> Users</span>
            </div>

            <table class="custom-table">
                <thead>
                    <tr>
                        <th>ผู้ใช้</th>
                        <th>Username</th>
                        <th>ตำแหน่ง</th>
                        <th style="text-align: right;">จัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof dbUsers !== 'undefined' && dbUsers.length > 0) { %>
                        <% dbUsers.forEach(function(u) { %>
                            <tr>
                                <td>
                                    <div class="staff-cell">
                                        <div class="staff-avatar">
                                            <%= u.name.charAt(0) %>
                                        </div>
                                        <div style="font-weight: 600;">
                                            <%= u.name %>
                                        </div>
                                    </div>
                                </td>
                                <td><span style="color: var(--text-muted);">@<%= u.username %></span></td>
                                <td><span class="role-badge"><%= u.role %></span></td>
                                <td style="text-align: right;">
                                    <div style="display: flex; justify-content: flex-end; gap: 15px;">
                                        <button onclick="openEditModal('<%= u.id %>', '<%= u.name %>', '<%= u.role %>')" class="btn-text" title="Edit">
                                            <span class="material-symbols-outlined">edit</span>
                                        </button>

                                        <form action="/admintool/delete/<%= u.id %>" method="POST" onsubmit="return confirm('Confirm Delete?');">
                                            <button type="submit" class="btn-text text-danger" title="Delete">
                                                <span class="material-symbols-outlined">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 40px;">
                                No users found in database.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <div id="addUserModal" class="modal-overlay">
        <div class="modal-box">
            <h2>Add New User</h2>
            <form action="/admintool/add" method="POST">
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" name="username" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" name="password" required>
                </div>
                <div class="form-group">
                    <label>Display Name</label>
                    <input type="text" name="name" required>
                </div>
                <div class="form-group">
                    <label>Role</label>
                    <select name="role" style="width: 100%; padding: 12px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px;">
                        <option value="admin">Admin</option>
                        <option value="staff">Staff</option>
                        <option value="manager">Manager</option>
                    </select>
                </div>
                <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px;">
                    <button type="button" onclick="closeModal('addUserModal')" class="btn-text">Cancel</button>
                    <button type="submit" class="btn-primary" style="width: auto;">Save User</button>
                </div>
            </form>
        </div>
    </div>

    <div id="editUserModal" class="modal-overlay">
        <div class="modal-box">
            <h2 style="margin-bottom: 20px; font-size: 20px;">Edit User</h2>
            <form id="editForm" method="POST">
                <div class="form-group">
                    <label>Display Name</label>
                    <input type="text" id="editName" name="name" required style="width: 100%; padding: 12px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px;">
                </div>
                <div class="form-group">
                    <label>Role</label>
                    <select id="editRole" name="role" style="width: 100%; padding: 12px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px;">
                        <option value="admin">Admin</option>
                        <option value="staff">Staff</option>
                        <option value="manager">Manager</option>
                    </select>
                </div>
                <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px;">
                    <button type="button" onclick="closeModal('editUserModal')" class="btn-text">Cancel</button>
                    <button type="submit" class="btn-primary" style="width: auto;">Update User</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openModal(id) {
            document.getElementById(id).classList.add('active');
        }
        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }
        function openEditModal(id, name, role) {
            document.getElementById('editForm').action = '/admintool/edit/' + id;
            document.getElementById('editName').value = name;
            document.getElementById('editRole').value = role;
            openModal('editUserModal');
        }

        //ถ้าเปิด overlay แล้วไปกด click ด้านนอกจะออกให้อัตโนมัติ
        window.onclick = function (event) {
            if (event.target.classList.contains('modal-overlay')) {
                event.target.classList.remove('active');
            }
        }
    </script>
</body>

</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GWMS AdminTools</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/history.css">
    <link rel="stylesheet" href="/css/navbar.css">
</head>
<body>
    <%- include('includes/navbar') %>
    <div class="history-wrapper">

        <!-- Header -->
        <div class="history-header">
            <div>
                <h1>กิจกรรมก่อนหน้า</h1>
                <p>ติดตามการเคลื่อนไหวของสินค้าในคลัง การปรับเปลี่ยนระบบ และกิจกรรมทำของพนักงาน</p>
            </div>
            <button class="export-btn">Export CSV</button>
        </div>


        <!-- Filter -->
        <div class="filter-box">

            <div class="filter-row">
                <div class="filter-group">
                    <label>ช่วงวันที่</label>
                    <input type="text" placeholder="Select dates">
                </div>

                <div class="filter-group">
                    <label>ประเภทของกิจกรรม</label>
                    <select>
                        <option>ทั้งหมด</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>พนักงาน</label>
                    <input type="text" placeholder="ค้นหาพนักงาน...">
                </div>

                <div style="display:flex;align-items:flex-end;">
                    <button class="filter-btn">Filter</button>
                </div>
            </div>

            <div class="quick-filters">
                <span style="color:#a1a1a1;font-size:12px;">QUICK FILTERS:</span>
                <div class="quick-pill pill-inbound">เพิ่ม</div>
                <div class="quick-pill pill-outbound">ลบ</div>
                <div class="quick-pill pill-edits">แก้ไข</div>
                <div class="quick-pill pill-audits">ตรวจสอบ</div>
            </div>

        </div>


        <!-- Table -->
        <table class="history-table">
    <thead>
        <tr>
            <th>LOG_ID</th>
            <th>ACTION TYPE</th>
            <th>TIMESTAMP</th>
            <th>USER</th>
            <th>PRODUCT</th>
        </tr>
    </thead>

    <tbody>

        <% logs.forEach(log => { %>

        <tr>
            <td><%= log.log_id %></td>
            
            <td>
            <% if (log.activity_type === "ADD_PRODUCT") { %>
                <span class="quick-pill pill-inbound">เพิ่ม</span>

            <% } else if (log.activity_type === "DELETE_PRODUCT") { %>
                <span class="quick-pill pill-outbound">ลบ</span>

            <% } else if (log.activity_type === "EDIT_PRODUCT") { %>
                <span class="quick-pill pill-edits">แก้ไข</span>

            <% } else { %>
                <span class="quick-pill pill-audits">ตรวจสอบ</span>
            <% } %>
            </td>

            <td><%= log.timestamp %></td>
            <td><%= log.user_name %></td>
            <td><%= log.product_name || '-' %></td>
        </tr>
        <% }) %>

    </tbody>
</table>


        <!-- Pagination -->
        <div class="pagination">
            <div class="page-btn">Previous</div>
            <div class="page-btn active">1</div>
            <div class="page-btn">2</div>
            <div class="page-btn">Next</div>
        </div>

    </div>
</body>
</html>
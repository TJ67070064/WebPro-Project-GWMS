<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GWMS - System Login</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="login-page">

    <main class="login-card">
        <div class="header">
            <h1 class="brand-title">GWMS</h1>
            <p class="brand-subtitle">Guitar Warehouse Management</p>
            <div class="brand-underline"></div>
        </div>

        <% if (error) { %>
            <div class="error-msg"><%= error %></div>
        <% } %>

        <form action="/login" method="POST">
            <div class="form-group">
                <label for="username">Username</label>
                <div class="input-wrapper">
                    <span class="material-symbols-outlined icon">person</span>
                    <input type="text" id="username" name="username" placeholder="Enter username" required>
                </div>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <div class="input-wrapper">
                    <span class="material-symbols-outlined icon">lock</span>
                    <input type="password" id="password" name="password" placeholder="••••••••" required>
                </div>
            </div>

            <button type="submit" class="btn-login">
                LOGIN <span class="material-symbols-outlined" style="font-size: 18px;">arrow_forward</span>
            </button>
            
        </form>

        <div class="footer-text">
            KMITL - Web Programming Project
        </div>
    </main>

</body>
</html>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GWMS Dashboard</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/navbar.css">
</head>

<body class="dashboard-layout">

   <%- include('includes/navbar') %>

    <main class="main-content">
        <div class="page-header">
            <div>
                <h2>สรุปภาพรวมแดชบอร์ด</h2>
                <p>ยินดีต้อนรับ, <%= user.name.split(' ')[0] %>. วันนี้ที่โกดังมีอะไรเกิดขึ้นบ้าง มาดูกัน</p>
            </div>
            
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon" style="background: var(--success-bg); color: var(--success);">
                        <span class="material-symbols-outlined">inventory_2</span>
                    </div>
                </div>
                <div class="stat-title">จำนวนสินค้าทั้งหมด (ชิ้น)</div>
                <div class="stat-value"><%= totalStock %></div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon" style="background: var(--danger-bg); color: var(--danger);">
                        <span class="material-symbols-outlined">warning</span>
                    </div>
                    <span class="badge danger">ตรวจสอบ</span>
                </div>
                <div class="stat-title">แจ้งเตือนสินค้าเหลือน้อย</div>
                <div class="stat-value"><%= lowStock %></div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon" style="background: var(--info-bg); color: var(--info);">
                        <span class="material-symbols-outlined">pending_actions</span>
                    </div>
                </div>
                <div class="stat-title">ออเดอร์รอการอนุมัติ</div>
                <div class="stat-value"><%= pendingOrders %></div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-icon" style="background: var(--warning-bg); color: var(--warning);">
                        <span class="material-symbols-outlined">history</span>
                    </div>
                    <span class="badge warning">> 50 ชิ้น</span>
                </div>
                <div class="stat-title">รายการสินค้าล้นสต็อค</div>
                <div class="stat-value"><%= overStock %></div>
            </div>
        </div>

        <div class="table-container">
            <div class="table-header">
                <h3>รายการที่ใช้งานล่าสุด (ตัวอย่าง):</h3>
                <a href="/history"
                    style="color: var(--primary); text-decoration: none; font-size: 14px; display: flex; align-items: center; gap: 5px;">
                    ดูประวัติทั้งหมด <span class="material-symbols-outlined"
                        style="font-size: 18px;">arrow_forward</span>
                </a>
            </div>
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>สถานะ</th>
                        <th>เรื่อง</th>
                        <th>พนักงาน</th>
                        <th>เวลา</th>
                        <th style="text-align: right;">รายละเอียด</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="badge success">Received</span></td>
                        <td style="font-weight: 600;">Inbound #3024</td>
                        <td>
                            <div class="staff-cell">
                                <div class="staff-avatar">M</div> Michael T.
                            </div>
                        </td>
                        <td style="color: var(--text-muted);">Just now</td>
                        <td style="text-align: right; color: var(--text-muted);">Fender Stratocaster (x5)</td>
                    </tr>
                    <tr>
                        <td><span class="badge info">Shipped</span></td>
                        <td style="font-weight: 600;">Order #8821</td>
                        <td>
                            <div class="staff-cell">
                                <div class="staff-avatar">S</div> Sarah J.
                            </div>
                        </td>
                        <td style="color: var(--text-muted);">15 mins ago</td>
                        <td style="text-align: right; color: var(--text-muted);">Gibson Les Paul Std</td>
                    </tr>
                    <tr>
                        <td><span class="badge warning">Audit</span></td>
                        <td style="font-weight: 600;">Zone B Count</td>
                        <td>
                            <div class="staff-cell">
                                <div class="staff-avatar">A</div> Alex G.
                            </div>
                        </td>
                        <td style="color: var(--text-muted);">45 mins ago</td>
                        <td style="text-align: right; color: var(--text-muted);">Discrepancy: -2 Units</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>

</body>

</html>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GWMS Dashboard</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/navbar.css">
</head>

<body class="dashboard-layout">

    <%- include('includes/navbar') %>

        <main class="main-content">
            <div class="page-header">
                <div>
                    <h2>สรุปภาพรวมแดชบอร์ด</h2>
                    <p>ยินดีต้อนรับ, <%= user.name.split(' ')[0] %>. วันนี้ที่โกดังมีอะไรเกิดขึ้นบ้าง มาดูกัน</p>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon" style="background: var(--success-bg); color: var(--success);">
                    <span class="material-symbols-outlined">inventory_2</span>
                </div>
            </div>
            <div class="stat-title">จำนวนสินค้าทั้งหมด (ชิ้น)</div>
            <div class="stat-value"><%= totalStock %></div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon" style="background: var(--danger-bg); color: var(--danger);">
                    <span class="material-symbols-outlined">warning</span>
                </div>
                <span class="badge danger">ตรวจสอบ</span>
            </div>
            <div class="stat-title">แจ้งเตือนสินค้าเหลือน้อย</div>
            <div class="stat-value"><%= lowStock %></div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon" style="background: var(--info-bg); color: var(--info);">
                    <span class="material-symbols-outlined">pending_actions</span>
                </div>
            </div>
            <div class="stat-title">ออเดอร์รอการอนุมัติ</div>
            <div class="stat-value"><%= pendingOrders %></div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <div class="stat-icon" style="background: var(--warning-bg); color: var(--warning);">
                    <span class="material-symbols-outlined">history</span>
                </div>
                <span class="badge warning">> 50 ชิ้น</span>
            </div>
            <div class="stat-title">รายการสินค้าล้นสต็อค</div>
            <div class="stat-value"><%= overStock %></div>
        </div>
    </div>

    <div class="bottom-layout-grid">
        
        <div class="table-container" style="padding: 24px;">
            <h3 style="margin-bottom: 20px; color: var(--text-main); font-size: 16px;">สัดส่วนประเภทสินค้าในคลัง</h3>
            <div id="chart"></div>
        </div>

        <div class="table-container">
            <div class="table-header">
                <h3 style="color: var(--text-main); font-size: 16px;">ประวัติการเข้าสู่ระบบล่าสุด (Login Logs):</h3>
            </div>
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>สถานะ</th>
                        <th>Username</th>
                        <th>ผู้ใช้งาน</th>
                        <th>IP Address</th>
                        <th style="text-align: right;">เวลาเข้าสู่ระบบ</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof loginLogs !== ' undefined' && loginLogs.length> 0) { %>
                            <% loginLogs.forEach(function(log) { %>
                                <tr>
                                    <td>
                                        <% if (log.status==='Success' ) { %>
                                            <span class="badge success">Success</span>
                                            <% } else if (log.status==='Logout' ) { %>
                                                <span class="badge danger">Logout</span>
                                                <% } else { %>
                                                    <span class="badge warning">Failed</span>
                                                    <% } %>
                                    </td>
                                    <td style="font-weight: 600; color: var(--primary);">@<%= log.username %>
                                    </td>
                                    <td>
                                        <%= log.display_name %>
                                    </td>
                                    <td style="color: var(--text-muted);">
                                        <%= log.ip_address %>
                                    </td>
                                    <td style="text-align: right; color: var(--text-muted);">
                                        <%= log.login_time %>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="5"
                                                style="text-align: center; color: var(--text-muted); padding: 30px;">
                                                ไม่มีประวัติการเข้าสู่ระบบ
                                            </td>
                                        </tr>
                                        <% } %>
                                            </tbody>
                                            </table>
                </div>
            </div>
        </main>
        <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

        <script>
            
            const seriesData = <%- JSON.stringify(chartSeries) %>;
            const labelsData = <%- JSON.stringify(chartLabels) %>;

            var options = {
                series: seriesData, 
                labels: labelsData, 
                chart: {
                    type: 'polarArea',
                    height: 350
                },
                stroke: {
                    colors: ['#fff']
                },
                fill: {
                    opacity: 0.8
                },
                legend: {
                    position: 'bottom',
                    labels: {
                        colors: '#FFFFFF',
                        useSeriesColors: false
                    }
                },
                responsive: [{
                    breakpoint: 480,
                    options: {
                        chart: {
                            width: 200
                        },
                        legend: {
                            position: 'bottom'
                        }
                    }
                }]
            };

            var chart = new ApexCharts(document.querySelector("#chart"), options);
            chart.render();
        </script>
</body>

</html>